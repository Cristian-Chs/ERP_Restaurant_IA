# ============================================================
# PRODUCCIÓN - Configuración para deployment
# ============================================================
# IMPORTANTE: Copiar este archivo a .env y completar con valores reales

# ============================================================
# DJANGO CONFIGURATION
# ============================================================
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=GENERAR-NUEVA-CLAVE-AQUI-NO-USAR-LA-DE-DESARROLLO

# PRODUCCIÓN: Siempre False
DEBUG=False

# PRODUCCIÓN: Agregar tu dominio
ALLOWED_HOSTS=tudominio.com,www.tudominio.com,api.tudominio.com

# ============================================================
# DATABASE (PostgreSQL en Producción)
# ============================================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=telegram_bot_prod
DB_USER=postgres_user_prod
DB_PASSWORD=CAMBIAR-PASSWORD-SEGURA-AQUI
DB_HOST=localhost
DB_PORT=5432

# ============================================================
# TELEGRAM BOT
# ============================================================
# PRODUCCIÓN: Considerar usar bot diferente o mismo token
BOT_TOKEN_CLIENTE=TU-TOKEN-DE-PRODUCCION
CHEF_CHAT_ID=TU-CHAT-ID
ADMIN_CHAT_ID=TU-CHAT-ID

# ============================================================
# API KEYS
# ============================================================
GROQ_API_KEY=TU-GROQ-KEY-PRODUCCION
OCR_API_KEY=TU-OCR-KEY-PRODUCCION

# ============================================================
# BACKEND URL (HTTPS en producción)
# ============================================================
BACKEND_URL=https://api.tudominio.com/api

# ============================================================
# CORS (Frontend URLs - HTTPS)
# ============================================================
CORS_ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ============================================================
# SEGURIDAD ADICIONAL (Opcional pero recomendado)
# ============================================================
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
